{
  "expo": {
    "name": "Cook Planner",
    "slug": "cook-planner",
    "version": "1.0.0",
    "scheme": "cookplanner",
    "orientation": "portrait",
    "icon": "./assets/images/book-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/book-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFBF7"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jbdg.cookplanner",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jbdg.cookplanner",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#FDFBF7"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4db3f905-b98a-4249-9b30-744a6783e5ec"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4db3f905-b98a-4249-9b30-744a6783e5ec"
    }
  }
}

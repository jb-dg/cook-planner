import { useState, useMemo, useRef } from "react";
import {
  View,
  Text,
  ScrollView,
  TextInput,
  TouchableOpacity,
  KeyboardAvoidingView,
  Platform,
  Dimensions,
  StyleSheet,
} from "react-native";
import { SafeAreaView } from "react-native-safe-area-context";
import { LinearGradient } from "expo-linear-gradient";
import { Feather } from "@expo/vector-icons";
import { format, addDays, startOfWeek, isSameDay } from "date-fns";
import { fr } from "date-fns/locale";
import { useAuth } from "../../contexts/AuthContext";
import { usePlannerData } from "../../features/planner/hooks/usePlannerData";
import { useAutoSave } from "../../features/planner/hooks/useAutoSave";

const { width } = Dimensions.get("window");

type MealType = "breakfast" | "lunch" | "dinner";

interface MealCardProps {
  type: MealType;
  time: string;
  label: string;
  placeholder: string;
  icon: "coffee" | "sun" | "moon";
  value: string;
  isActive: boolean;
  onPress: () => void;
  onChangeText: (text: string) => void;
  onSubmit: () => void;
  onCancel: () => void;
}

// Meal Card Component
const MealCard = ({
  type,
  time,
  label,
  placeholder,
  icon,
  value,
  isActive,
  onPress,
  onChangeText,
  onSubmit,
  onCancel,
}: MealCardProps) => {
  const inputRef = useRef<TextInput>(null);

  const gradientColors = {
    breakfast: ["#FBBF24", "#F97316"],
    lunch: ["#34D399", "#10B981"],
    dinner: ["#6366F1", "#A855F7"],
  };

  const accentColor = {
    breakfast: "#F97316",
    lunch: "#10B981",
    dinner: "#A855F7",
  };

  return (
    <View style={styles.mealCard}>
      {/* Header avec icône et info */}
      <View style={styles.mealHeader}>
        <LinearGradient
          colors={gradientColors[type] as [string, string]}
          style={styles.mealIcon}
          start={{ x: 0, y: 0 }}
          end={{ x: 1, y: 1 }}
        >
          <Feather name={icon} size={32} color="#FFF" />
        </LinearGradient>

        <View style={styles.mealInfo}>
          <Text style={styles.mealLabel}>{label}</Text>
          <View style={styles.mealTimeRow}>
            <Feather name="clock" size={14} color={accentColor[type]} />
            <Text style={[styles.mealTime, { color: accentColor[type] }]}>
              {time}
            </Text>
            <Text style={styles.mealStatus}>
              {value ? "Planifié" : "Non planifié"}
            </Text>
          </View>
        </View>
      </View>

      {/* Zone de saisie ou CTA */}
      {!isActive && !value ? (
        // Mode CTA (vide)
        <TouchableOpacity
          activeOpacity={0.7}
          onPress={onPress}
          style={styles.ctaContainer}
        >
          <LinearGradient
            colors={[`${accentColor[type]}15`, `${accentColor[type]}05`] as [string, string]}
            style={styles.ctaGradient}
          >
            <View style={styles.ctaContent}>
              <LinearGradient
                colors={gradientColors[type] as [string, string]}
                style={styles.ctaPlusIcon}
                start={{ x: 0, y: 0 }}
                end={{ x: 1, y: 1 }}
              >
                <Feather name="plus" size={28} color="#FFF" />
              </LinearGradient>
              <View>
                <Text style={styles.ctaTitle}>Ajouter un repas</Text>
                <Text style={styles.ctaSubtitle}>Saisie rapide en 1 tap</Text>
              </View>
            </View>
          </LinearGradient>
        </TouchableOpacity>
      ) : isActive ? (
        // Mode saisie active
        <View style={styles.inputContainer}>
          <View style={styles.inputRow}>
            <TextInput
              ref={inputRef}
              style={[styles.input, { fontSize: 16 }]} // Important pour éviter zoom iOS
              value={value}
              onChangeText={onChangeText}
              placeholder={placeholder}
              placeholderTextColor="#9CA3AF"
              autoFocus
              returnKeyType="done"
              onSubmitEditing={onSubmit}
            />
            <TouchableOpacity
              style={styles.inputButton}
              onPress={onCancel}
              activeOpacity={0.7}
            >
              <Feather name="x" size={24} color="#EF4444" />
            </TouchableOpacity>
            <TouchableOpacity
              style={[styles.inputButton, styles.inputButtonConfirm]}
              onPress={onSubmit}
              activeOpacity={0.7}
            >
              <Feather name="check" size={24} color="#10B981" />
            </TouchableOpacity>
          </View>

          {/* Quick-add buttons */}
          <ScrollView
            horizontal
            showsHorizontalScrollIndicator={false}
            style={styles.quickAddScroll}
            contentContainerStyle={styles.quickAddContent}
          >
            <TouchableOpacity style={styles.quickAddButton} activeOpacity={0.7}>
              <Feather name="clock" size={16} color="#6B7280" />
              <Text style={styles.quickAddText}>10 min</Text>
            </TouchableOpacity>
            <TouchableOpacity style={styles.quickAddButton} activeOpacity={0.7}>
              <Feather name="users" size={16} color="#6B7280" />
              <Text style={styles.quickAddText}>2 pers</Text>
            </TouchableOpacity>
            <TouchableOpacity style={styles.quickAddButton} activeOpacity={0.7}>
              <Feather name="book-open" size={16} color="#6B7280" />
              <Text style={styles.quickAddText}>Recette</Text>
            </TouchableOpacity>
          </ScrollView>

          <View style={styles.hintRow}>
            <Feather name="info" size={14} color="#6B7280" />
            <Text style={styles.hintText}>
              Appuyez sur Entrée ou ✓ pour valider
            </Text>
          </View>
        </View>
      ) : (
        // Mode affichage (avec valeur)
        <TouchableOpacity onPress={onPress} activeOpacity={0.7}>
          <View style={styles.valueContainer}>
            <Text style={styles.valueText}>{value}</Text>
            <Feather name="edit-2" size={18} color="#6B7280" />
          </View>
        </TouchableOpacity>
      )}
    </View>
  );
};

export default function ModernPlannerScreen() {
  const { session } = useAuth();
  const [selectedDayIndex, setSelectedDayIndex] = useState(5); // Samedi par défaut
  const [quickInputActive, setQuickInputActive] = useState<MealType | null>(
    null
  );
  const [quickInputValues, setQuickInputValues] = useState({
    breakfast: "",
    lunch: "",
    dinner: "",
  });

  // Date management
  const referenceDate = useMemo(
    () => startOfWeek(new Date(), { weekStartsOn: 1 }),
    []
  );

  const selectedDate = useMemo(
    () => addDays(referenceDate, selectedDayIndex),
    [referenceDate, selectedDayIndex]
  );

  // Data & Auto-save
  const { days, setDays, syncing } = usePlannerData(session, referenceDate);
  const { saveStatus } = useAutoSave(days, session, referenceDate, true, 2000);

  // Stats calculation
  const stats = useMemo(() => {
    const totalSlots = days.length * 2; // lunch + dinner
    const filled = days.reduce((acc, day) => {
      let count = 0;
      if (day.lunch?.recipe?.trim()) count++;
      if (day.dinner?.recipe?.trim()) count++;
      return acc + count;
    }, 0);
    const percent = Math.round((filled / totalSlots) * 100);
    const remaining = totalSlots - filled;

    return {
      percent,
      filled,
      remaining,
    };
  }, [days]);

  // Week days for navigation
  const weekDays = useMemo(() => {
    return Array.from({ length: 7 }).map((_, index) => {
      const date = addDays(referenceDate, index);
      return {
        index,
        dayName: format(date, "EEE", { locale: fr }).toUpperCase(),
        dayNumber: format(date, "d"),
        date,
      };
    });
  }, [referenceDate]);

  // Handlers
  const handleMealPress = (type: MealType) => {
    setQuickInputActive(type);
  };

  const handleInputChange = (type: MealType, text: string) => {
    setQuickInputValues((prev) => ({ ...prev, [type]: text }));
  };

  const handleSubmit = (type: MealType) => {
    const value = quickInputValues[type];
    if (!value.trim()) return;

    // Update days data
    setDays((prevDays) => {
      const newDays = [...prevDays];
      const day = { ...newDays[selectedDayIndex] };

      if (type === "breakfast") {
        // Note: breakfast n'existe pas dans le modèle actuel, on pourrait l'ajouter
        // Pour l'instant, on utilise lunch
        day.lunch = { recipe: value };
      } else {
        day[type] = { recipe: value };
      }

      newDays[selectedDayIndex] = day;
      return newDays;
    });

    setQuickInputValues((prev) => ({ ...prev, [type]: "" }));
    setQuickInputActive(null);
  };

  const handleCancel = (type: MealType) => {
    setQuickInputValues((prev) => ({ ...prev, [type]: "" }));
    setQuickInputActive(null);
  };

  const handleGoToToday = () => {
    const today = new Date();
    const todayIndex = weekDays.findIndex((day) => isSameDay(day.date, today));
    if (todayIndex !== -1) {
      setSelectedDayIndex(todayIndex);
    }
  };

  const currentDayMeals = useMemo(() => {
    const day = days[selectedDayIndex];
    return {
      breakfast: "", // Pas dans le modèle actuel
      lunch: day?.lunch?.recipe || "",
      dinner: day?.dinner?.recipe || "",
    };
  }, [days, selectedDayIndex]);

  return (
    <SafeAreaView style={styles.safeArea} edges={["top", "left", "right"]}>
      <KeyboardAvoidingView
        behavior={Platform.OS === "ios" ? "padding" : "height"}
        style={styles.keyboardView}
      >
        <ScrollView
          style={styles.scrollView}
          contentContainerStyle={styles.scrollContent}
          showsVerticalScrollIndicator={false}
        >
          {/* HEADER */}
          <View style={styles.header}>
            <View style={styles.headerTop}>
              <Text style={styles.title}>Planning</Text>
              <TouchableOpacity
                style={styles.todayButton}
                onPress={handleGoToToday}
                activeOpacity={0.7}
              >
                <Text style={styles.todayButtonText}>Aujourd'hui</Text>
              </TouchableOpacity>
            </View>

            <Text style={styles.subtitle}>
              Semaine du {format(referenceDate, "d MMMM", { locale: fr })}
            </Text>

            {/* Stats */}
            <View style={styles.statsGrid}>
              <LinearGradient
                colors={["#FED7AA", "#FFEDD5"]}
                style={styles.statCard}
                start={{ x: 0, y: 0 }}
                end={{ x: 1, y: 1 }}
              >
                <Text style={styles.statValue}>{stats.percent}%</Text>
                <Text style={styles.statLabel}>Planifiés</Text>
              </LinearGradient>

              <LinearGradient
                colors={["#A7F3D0", "#D1FAE5"]}
                style={styles.statCard}
                start={{ x: 0, y: 0 }}
                end={{ x: 1, y: 1 }}
              >
                <Text style={styles.statValue}>{stats.filled}</Text>
                <Text style={styles.statLabel}>Prêts</Text>
              </LinearGradient>

              <LinearGradient
                colors={["#FDE68A", "#FEF3C7"]}
                style={styles.statCard}
                start={{ x: 0, y: 0 }}
                end={{ x: 1, y: 1 }}
              >
                <Text style={styles.statValue}>{stats.remaining}</Text>
                <Text style={styles.statLabel}>À planifier</Text>
              </LinearGradient>
            </View>
          </View>

          {/* DAY NAVIGATION */}
          <View style={styles.dayNavContainer}>
            <TouchableOpacity
              style={styles.navArrow}
              onPress={() =>
                setSelectedDayIndex((prev) => Math.max(0, prev - 1))
              }
              activeOpacity={0.7}
            >
              <Feather name="chevron-left" size={20} color="#111827" />
            </TouchableOpacity>

            <ScrollView
              horizontal
              showsHorizontalScrollIndicator={false}
              style={styles.dayScroll}
              contentContainerStyle={styles.dayScrollContent}
            >
              {weekDays.map((day) => (
                <TouchableOpacity
                  key={day.index}
                  style={[
                    styles.dayButton,
                    selectedDayIndex === day.index && styles.dayButtonActive,
                  ]}
                  onPress={() => setSelectedDayIndex(day.index)}
                  activeOpacity={0.7}
                >
                  <Text
                    style={[
                      styles.dayName,
                      selectedDayIndex === day.index && styles.dayNameActive,
                    ]}
                  >
                    {day.dayName}
                  </Text>
                  <Text
                    style={[
                      styles.dayNumber,
                      selectedDayIndex === day.index && styles.dayNumberActive,
                    ]}
                  >
                    {day.dayNumber}
                  </Text>
                </TouchableOpacity>
              ))}
            </ScrollView>

            <TouchableOpacity
              style={styles.navArrow}
              onPress={() =>
                setSelectedDayIndex((prev) => Math.min(6, prev + 1))
              }
              activeOpacity={0.7}
            >
              <Feather name="chevron-right" size={20} color="#111827" />
            </TouchableOpacity>
          </View>

          {/* MEAL CARDS */}
          <View style={styles.mealsContainer}>
            <MealCard
              type="breakfast"
              time="8h00"
              label="Petit-déjeuner"
              placeholder="Ex: Pain grillé et confiture"
              icon="coffee"
              value={currentDayMeals.breakfast}
              isActive={quickInputActive === "breakfast"}
              onPress={() => handleMealPress("breakfast")}
              onChangeText={(text) => handleInputChange("breakfast", text)}
              onSubmit={() => handleSubmit("breakfast")}
              onCancel={() => handleCancel("breakfast")}
            />

            <MealCard
              type="lunch"
              time="12h30"
              label="Déjeuner"
              placeholder="Ex: Pâtes carbonara"
              icon="sun"
              value={currentDayMeals.lunch}
              isActive={quickInputActive === "lunch"}
              onPress={() => handleMealPress("lunch")}
              onChangeText={(text) => handleInputChange("lunch", text)}
              onSubmit={() => handleSubmit("lunch")}
              onCancel={() => handleCancel("lunch")}
            />

            <MealCard
              type="dinner"
              time="19h30"
              label="Dîner"
              placeholder="Ex: Poulet rôti et légumes"
              icon="moon"
              value={currentDayMeals.dinner}
              isActive={quickInputActive === "dinner"}
              onPress={() => handleMealPress("dinner")}
              onChangeText={(text) => handleInputChange("dinner", text)}
              onSubmit={() => handleSubmit("dinner")}
              onCancel={() => handleCancel("dinner")}
            />
          </View>

          {/* Save Status */}
          {saveStatus === "saving" && (
            <View style={styles.saveIndicator}>
              <Feather name="loader" size={14} color="#6B7280" />
              <Text style={styles.saveText}>Enregistrement...</Text>
            </View>
          )}
        </ScrollView>
      </KeyboardAvoidingView>
    </SafeAreaView>
  );
}

